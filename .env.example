# Generate values with: openssl rand -hex 32
# Copy this file to .env and fill in actual values: cp .env.example .env

# Qdrant internal API key (Caddy holds this, never exposed to clients)
QDRANT_API_KEY=replace_with_openssl_rand_hex_32

# Postgres credentials
POSTGRES_PASSWORD=replace_with_openssl_rand_hex_32

# Client-facing token for /qdrant/* route (Caddy verifies)
MCP_BEARER_TOKEN=replace_with_openssl_rand_hex_32

# Client-facing token for /archive/* route (archive-api verifies)
ARCHIVE_AUTH_TOKEN=replace_with_openssl_rand_hex_32

# (Optional) Neon Cloud Postgres — use INSTEAD of local Postgres for low-RAM VPS
# NEON_DB_URL=postgresql://neondb_owner:<password>@ep-<id>.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Token cho memory-rest-api (ChatGPT Custom GPT + MCP add_memory/search_memories)
CHATGPT_AUTH_TOKEN=replace_with_openssl_rand_hex_32

# MCP HTTP server -> memory-rest-api (mem0)
MEMORY_API_URL=http://memory-rest-api:8002
MEMORY_API_TOKEN=${CHATGPT_AUTH_TOKEN}
